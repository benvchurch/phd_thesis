\begin{tikzpicture}%
\draw (0,0) -- (1ex,0ex);%
\draw (1ex,0ex) -- (1ex,1ex);%
\end{tikzpicture}}

\newsavebox{\pushoutsymbol}
\sbox\pushoutsymbol{%
\begin{tikzpicture}%
\draw (0,0) -- (-1ex,0ex);%
\draw (-1ex,0ex) -- (-1ex,-1ex);%
\end{tikzpicture}}

